# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# Google Safe Browsing API key
# Get one at: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here

# Port the Express server listens on (default: 5000)
PORT=5000

# URL of the Python ML micro-service (default: http://127.0.0.1:5001)
ML_SERVICE_URL=http://127.0.0.1:5001

# Public URL of this backend (e.g., https://your-backend.onrender.com)
# Used by the frontend/uptime monitor to reach this API
SELF_URL=

# Comma-separated list of browser origins allowed to call this API (CORS).
# Example: https://your-frontend.vercel.app,http://localhost:5173
# Leave blank ONLY for local dev — in production this must be set to lock CORS down.
ALLOWED_ORIGINS=

# Shared secret sent to the ML service on /predict calls. Must match ML_INTERNAL_TOKEN
# in the ml-service environment. Generate a long random string.
ML_INTERNAL_TOKEN=

# Set to 1 to enable verbose request logging (prints URLs/responses). Keep off in production.
DEBUG_LOGS=0
