# ── Environment / Secrets ────────────────────────────────────────────────────
# Never commit real .env files
.env
.env.local
.env.*.local
# Commit .env.example files (they contain no secrets)
!.env.example

# ── Node / JavaScript ────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
.venv/
env/
.env/
.ipynb_checkpoints/

# ── ML Artifacts (large binary / dataset files) ──────────────────────────────
# These are too large for Git — use Git LFS or a separate storage bucket
ml-service/*.csv
ml-service/*.pkl
ml-service/*.zip
ml-service/*.h5
ml-service/*.pt
ml-service/*.bin

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
