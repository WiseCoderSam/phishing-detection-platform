# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# Shared secret required on JSON /predict calls (the backend -> ML channel).
# Must match ML_INTERNAL_TOKEN in the backend environment. Generate a long random string.
# Leave blank ONLY for local dev — in production this must be set to lock the API down.
ML_INTERNAL_TOKEN=

# Comma-separated list of browser origins allowed to call this service (CORS).
# The built-in demo form at "/" is same-origin and unaffected. Leave blank for local dev.
ALLOWED_ORIGINS=

# Set to 1 to enable Flask debug mode (Werkzeug debugger). NEVER enable in production.
FLASK_DEBUG=0
